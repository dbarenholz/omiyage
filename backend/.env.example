# ──────────────────────────────────────────────────────────────────────────────
# Backend and database environment variables
# Copy this file to .env and fill in the values.
# This file is used by both the backend container and the Postgres container.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL database name
POSTGRES_DB=omiyage

# PostgreSQL user
POSTGRES_USER=omiyage

# REQUIRED — PostgreSQL password. Must not be empty.
POSTGRES_PASSWORD=

# The port the Spring Boot server listens on.
# Keep this aligned with docker-compose.yml unless you also update the port mapping.
SERVER_PORT=8080

# Base path for the backend API when running behind a reverse proxy at a subpath.
# For subdomain deployments (omiyage.example.com): leave as /
# For subpath deployments (example.com/omiyage):   set to /omiyage/api
SERVER_SERVLET_CONTEXT_PATH=/

# Optional Spring Boot database overrides.
# Leave these unset to derive the connection from POSTGRES_DB, POSTGRES_USER,
# and POSTGRES_PASSWORD above.
# DATABASE_URL=jdbc:postgresql://db:5432/omiyage
# DATABASE_USERNAME=omiyage
# DATABASE_PASSWORD=

# Comma-separated list of origins allowed to call the API.
# Use * in development; set to your frontend origin in production.
CORS_ALLOWED_ORIGINS=*

# Minutes before a never-logged-in account is deleted.
CLEANUP_INACTIVE_ACCOUNT_MINUTES=15

# MinIO credentials and object storage settings.
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are consumed by the MinIO container.
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY are consumed by the backend.
# Keep them aligned unless you intentionally separate app and root credentials.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=omiyage-images