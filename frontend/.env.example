# ──────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env and fill in the values.
# Variables prefixed PUBLIC_ are embedded at build time and visible in the browser.
# The Docker Compose mapping publishes port 3000 on the host.
# ──────────────────────────────────────────────────────────────────────────────

# The scheme + hostname the browser uses to reach the backend API.
# For local development:          http://localhost
# For subdomain deployment:       https://api.omiyage.example.com
# For subpath deployment:         https://example.com
PUBLIC_API_URL=http://localhost

# The port the backend API listens on (as seen from the browser).
# Set to "" (empty) to omit the port (i.e. when behind a reverse proxy on 80/443).
PUBLIC_API_PORT=8080

# The base path of the API on the backend host.
# Default is /api (matches the backend's /api prefix).
# For subpath deployment (e.g. example.com/omiyage/api): /omiyage/api
PUBLIC_API_PATH=/api

# The base path for the frontend itself when it is served at a subpath.
# Leave empty for root or subdomain deployments.
# Example: /omiyage
PUBLIC_BASE_PATH=

# The port this frontend server listens on.
# Keep this aligned with docker-compose.yml unless you also update the port mapping.
PORT=3000
