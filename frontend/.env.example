# ──────────────────────────────────────────────────────────────────────────────
# Frontend environment variables
# Copy this file to .env and fill in the values.
# Variables prefixed PUBLIC_ are embedded at build time and visible in the browser.
# The Docker Compose mapping publishes port 3000 on the host.
# ──────────────────────────────────────────────────────────────────────────────

# The scheme + hostname the browser uses to reach the backend API.
# For local development:          http://localhost
# For subdomain deployment:       https://api.omiyage.example.com
# For subpath deployment:         https://example.com
PUBLIC_API_URL=http://localhost

# The port the backend API listens on (as seen from the browser).
# Set to "" (empty) to omit the port (i.e. when behind a reverse proxy on 80/443).
PUBLIC_API_PORT=8080

# The base path of the API on the backend host.
# Default is /api (matches the backend's /api prefix).
# For subpath deployment (e.g. example.com/omiyage/api): /omiyage/api
PUBLIC_API_PATH=/api

# The base path for the frontend itself when it is served at a subpath.
# Leave empty for root or subdomain deployments.
# Example: /omiyage
PUBLIC_BASE_PATH=

# ──────────────────────────────────────────────────────────────────────────────
# INTERNAL API ROUTING (SSR ONLY)
# ──────────────────────────────────────────────────────────────────────────────
# Why do we need this? 
# In a local Docker Compose setup, your browser connects to the backend using 
# PUBLIC_API_URL (e.g., http://localhost:8080).
# However, during Server-Side Rendering (SSR), SvelteKit runs *inside* a Docker container.
# If SvelteKit tries to fetch from http://localhost:8080, the connection is refused 
# because 'localhost' inside the container points to the SvelteKit container itself!
# 
# INTERNAL_API_URL catches any SSR requests aimed at localhost:8080 and dynamically 
# reroutes them through the internal Docker network instead.
# 
# For local Docker Compose:       http://backend:8080/
# For CI/CD (or single networks): (Leave empty or omit)
INTERNAL_API_URL=http://backend:8080/

# The port this frontend server listens on.
# Keep this aligned with docker-compose.yml unless you also update the port mapping.
PORT=3000

# ──────────────────────────────────────────────────────────────────────────────
# PLAYWRIGHT E2E TESTING
# ──────────────────────────────────────────────────────────────────────────────
# By default, running Playwright tests will automatically build the frontend 
# and start a SvelteKit preview server on port 4173.
# 
# If you want to run Playwright tests against an already running server 
# (e.g. against a production Docker container in CI/CD), set:
# PLAYWRIGHT_SKIP_WEBSERVER=true
# 
# And explicitly specify the URL where the frontend is running:
# PLAYWRIGHT_BASE_URL=http://localhost:3000
